# FoxChatRAG 配置文件示例
# 复制此文件为 .env 并填写实际配置

# ============ RabbitMQ 配置 ============
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USER=admin
RABBITMQ__PASSWORD=admin
RABBITMQ__RAG_QUEUE=rag.queue
RABBITMQ__CHAT_QUEUE=chat.queue

# ============ MySQL 配置 ============
MYSQL__HOST=localhost
MYSQL__PORT=3306
MYSQL__USER=root
MYSQL__PASSWORD=your_password_here
MYSQL__DATABASE=FoxChat

# ============ Redis 配置 ============
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__USER=default
REDIS__PASSWORD=
REDIS__DB=0

# ============ LLM API Keys ============
KEY__DS_MODEL=your_deepseek_api_key_here
KEY__KIMI_MODEL=your_kimi_api_key_here
KEY__QWEN_MODEL=your_qwen_api_key_here
KEY__MiniMax_MODEL=your_minimax_api_key_here

# ============ 服务器配置 ============
SERVER__PORT=8000

# ============ 模型配置 ============
# 可选值：ds_model, json_ds_model, kimi_model, minimax_model, minimax_json_model, qwen4b_model

# 默认 LLM 模型
MODEL__DEFAULT_LLM=ds_model
MODEL__DEFAULT_JSON_LLM=json_ds_model
MODEL__DEFAULT_EMBEDDING=dashscope

# ============ 按场景配置（可选） ============
# 如果不配置，默认使用上面的全局默认模型
# 设置为 "default" 表示使用全局默认，"default_json" 表示使用 JSON 模型

# 聊天场景
MODEL_BY_SCENARIO__CHAT_LLM=default
MODEL_BY_SCENARIO__CHAT_JSON_LLM=default_json

# 记忆场景（总结、用户画像等）
MODEL_BY_SCENARIO__MEMORY_LLM=default
MODEL_BY_SCENARIO__MEMORY_JSON_LLM=default_json

# 消息总结场景
MODEL_BY_SCENARIO__SUMMARY_LLM=default

# 信息抽取场景
MODEL_BY_SCENARIO__EXTRACTION_LLM=default
