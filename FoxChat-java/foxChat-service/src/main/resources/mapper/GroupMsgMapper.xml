<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bedfox.service.mapper.GroupMsgMapper">

    <resultMap id="BaseResultMap" type="com.bedfox.pojo.domain.GroupMsg">
            <id property="id" column="id" />
            <result property="groupId" column="group_id" />
            <result property="sendUserId" column="send_user_id" />
            <result property="msgContent" column="msg_content" />
            <result property="msgType" column="msg_type" />
            <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,group_id,send_user_id,msg_content,msg_type,create_time
    </sql>

    <select id="historyMsg" resultType="com.bedfox.pojo.domain.GroupMsg">
        SELECT
        <include refid="Base_Column_List"/>
        FROM group_msg
        WHERE group_id = #{groupId}
        AND create_time &lt; #{dateTime}
        ORDER BY create_time DESC
        LIMIT 20
    </select>
</mapper>
