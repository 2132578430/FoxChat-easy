<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bedfox.service.mapper.UsersMapper">

    <resultMap id="BaseResultMap" type="com.bedfox.pojo.domain.Users">
            <id property="id" column="id" />
            <result property="username" column="username" />
            <result property="password" column="password" />
            <result property="faceImage" column="face_image" />
            <result property="faceImageBig" column="face_image_big" />
            <result property="nickname" column="nickname" />
            <result property="qrcode" column="qrcode" />
            <result property="cid" column="cid" />
            <result property="email" column="email" />
    </resultMap>

    <sql id="Base_Column_List">
        id,username,password,face_image,face_image_big,nickname,email
        qrcode,cid
    </sql>
</mapper>
