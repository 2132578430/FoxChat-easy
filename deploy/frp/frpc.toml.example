# ============================================
# frpc 客户端配置 — 部署在本机 WSL
# frp version >= 0.61 (TOML 格式)
# 复制为 frpc.toml 并填写实际值：cp frpc.toml.example frpc.toml
# ============================================

# 连接服务器 frps
serverAddr = "your-server-ip-here"
serverPort = 7000

# 认证令牌（与 frps.toml 一致）
auth.token = "change-me-to-a-random-string"

# ============================================
# TCP 端口映射
# ============================================

[[proxies]]
name = "mysql"
type = "tcp"
localIP = "127.0.0.1"
localPort = 3306
remotePort = 13306

[[proxies]]
name = "redis"
type = "tcp"
localIP = "127.0.0.1"
localPort = 6379
remotePort = 16379

[[proxies]]
name = "chromadb"
type = "tcp"
localIP = "127.0.0.1"
localPort = 8000
remotePort = 18000

[[proxies]]
name = "minio-api"
type = "tcp"
localIP = "127.0.0.1"
localPort = 9000
remotePort = 19000

[[proxies]]
name = "minio-console"
type = "tcp"
localIP = "127.0.0.1"
localPort = 9001
remotePort = 19001

[[proxies]]
name = "rabbitmq-amqp"
type = "tcp"
localIP = "127.0.0.1"
localPort = 5672
remotePort = 15672

[[proxies]]
name = "rabbitmq-mgmt"
type = "tcp"
localIP = "127.0.0.1"
localPort = 15672
remotePort = 25672