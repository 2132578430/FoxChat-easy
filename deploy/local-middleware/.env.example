# ============================================
# FoxChat 本机中间件环境变量
# 与服务器 /root/home/docker-manager/.env 保持完全一致
# 复制为 .env 即可使用：cp .env.example .env
# ============================================

# ============ MySQL ============
MYSQL_ROOT_PASSWORD=root123

# ============ Redis ============
REDIS_PASSWORD=root

# ============ RabbitMQ ============
RABBIT_USER=admin
RABBIT_PASSWORD=admin

# ============ MinIO ============
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
