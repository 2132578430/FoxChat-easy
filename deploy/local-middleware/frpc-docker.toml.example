# ============================================
# frpc Docker 版配置 — 使用 Docker 网络内服务名
# 部署在本机 WSL Docker，与中间件在同一 compose
# 复制为 frpc-docker.toml 并填写实际值：cp frpc-docker.toml.example frpc-docker.toml
# ============================================

serverAddr = "your-server-ip-here"
serverPort = 7000

auth.token = "change-me-to-a-random-string"

# Docker 网络内可直接用 service name
[[proxies]]
name = "mysql"
type = "tcp"
localIP = "mysql"
localPort = 3306
remotePort = 13306

[[proxies]]
name = "redis"
type = "tcp"
localIP = "redis"
localPort = 6379
remotePort = 16379

[[proxies]]
name = "chromadb"
type = "tcp"
localIP = "chromadb"
localPort = 8000
remotePort = 18000

[[proxies]]
name = "minio-api"
type = "tcp"
localIP = "minio"
localPort = 9000
remotePort = 19000

[[proxies]]
name = "minio-console"
type = "tcp"
localIP = "minio"
localPort = 9001
remotePort = 19001

[[proxies]]
name = "rabbitmq-amqp"
type = "tcp"
localIP = "rabbitmq"
localPort = 5672
remotePort = 15672

[[proxies]]
name = "rabbitmq-mgmt"
type = "tcp"
localIP = "rabbitmq"
localPort = 15672
remotePort = 25672